{
  "name": "@signage/player-tizen",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:mock": "vite --mode mock",
    "build": "bash scripts/package-wgt.sh",
    "wgt:install": "bash scripts/install-emulator.sh",
    "wgt:run": "bash scripts/run-emulator.sh",
    "wgt:deploy": "pnpm run build && pnpm run wgt:install",
    "wgt:deploy:run": "pnpm run wgt:deploy && pnpm run wgt:run",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@signage/config": "workspace:*",
    "@signage/contracts": "workspace:*",
    "@unocss/reset": "^66.6.2",
    "axios": "^1.13.5",
    "mqtt": "^5.15.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
