{
  "name": "@signage/player-tizen",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:mock": "vite --mode mock",
    "build": "vue-tsc && vite build",
    "build:tizen": "vite build --mode tizen",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@signage/config": "workspace:*",
    "@signage/contracts": "workspace:*",
    "axios": "^1.13.5",
    "mqtt": "^5.15.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
