{
  "name": "@signage/player-tizen",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:mock": "vite --mode mock",
    "build": "vue-tsc && vite build",
    "build:tizen": "vite build --mode tizen",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@signage/contracts": "workspace:*",
    "@signage/config": "workspace:*",
    "axios": "^1.6.0",
    "mqtt": "^5.3.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "vue-tsc": "^1.8.0"
  }
}
